# Required
ANTHROPIC_API_KEY=your-api-key-here

# Upstash Redis (required — for data persistence)
UPSTASH_REDIS_REST_URL=your-redis-url-here
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# Google Calendar (optional — for calendar sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=

# Notion (optional — ready to plug in when needed)
NOTION_API_KEY=
NOTION_DATABASE_ID=
